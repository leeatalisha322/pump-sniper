# ── Helius LaserStream gRPC ────────────────────────────────────────────────────
HELIUS_LASERSTREAM_ENDPOINT=https://mainnet.helius-rpc.com:10000
HELIUS_API_KEY=your-helius-api-key-here

# ── Solana RPC (for sending transactions) ─────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-api-key-here

# ── Wallet ─────────────────────────────────────────────────────────────────────
# Base58-encoded private key  (keep this secret, never commit)
WALLET_PRIVATE_KEY=your-base58-private-key-here

# ── Creator filter ─────────────────────────────────────────────────────────────
# Comma-separated creator wallet addresses to buy from (leave empty = buy from anyone)
CREATOR_WHITELIST=
# Comma-separated addresses to always skip
CREATOR_BLACKLIST=

# ── Buy parameters ─────────────────────────────────────────────────────────────
BUY_AMOUNT_SOL=0.05          # SOL to spend per snipe
SLIPPAGE_BPS=300             # 3% slippage tolerance
PRIORITY_FEE_MICROLAMPORTS=100000  # priority fee for fast landing

# ── Position management ────────────────────────────────────────────────────────
TAKE_PROFIT_PERCENT=100      # sell when up this % (100 = 2x)
STOP_LOSS_PERCENT=30         # sell when down this %
MAX_OPEN_POSITIONS=5         # max simultaneous positions
