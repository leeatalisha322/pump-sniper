{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install all dependencies",
      "type": "process",
      "command": "npm",
      "args": ["install", "--include=dev", "--include=optional"],
      "windows": {
        "command": "npm.cmd"
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NODE_ENV": "development"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
